<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Todo para tus uñas - Catálogo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<style>
:root{
  --rosa:#e91e63;
  --morado:#9c27b0;
  --rosa-osc:#ad1457;
  --gris:#f9f5f9;
  --sombra:0 8px 24px rgba(173,20,87,0.12);
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:'Montserrat',sans-serif;
  background:#fff;
  color:#222;
  line-height:1.5;
}
img{max-width:100%;display:block}
button{font-family:inherit}
.banner-principal,.banner-secundario{
  width:100%;
  height:auto;
  display:block;
  object-fit:cover;
}
.banner-principal{max-height:75vh}
.banner-secundario{max-height:45vh;margin-top:3px}

/* REELS */
.reels{
  background:linear-gradient(135deg,#e91e63 0%,#9c27b0 100%);
  padding:50px 20px;
  color:white;
}
.reels .container{max-width:1300px;margin:0 auto}
.reels h2{
  font-family:'Playfair Display',serif;
  text-align:center;
  font-size:2.2rem;
  margin-bottom:35px;
  text-shadow:0 2px 10px rgba(0,0,0,.2);
}
.reels-grid{
  display:grid;
  gap:20px;
  grid-template-columns:1fr;
}
@media(min-width:600px){.reels-grid{grid-template-columns:repeat(2,1fr)}}
@media(min-width:1024px){.reels-grid{grid-template-columns:repeat(4,1fr)}}
.reels-grid blockquote{
  background:white!important;
  border-radius:12px!important;
  overflow:hidden;
  box-shadow:var(--sombra);
}

/* CATALOGO */
#catalogo{padding:20px 0 100px;background:var(--gris)}
.titulo-catalogo{
  font-family:'Playfair Display',serif;
  text-align:center;
  font-size:2.5rem;
  margin:40px 0 35px;
  color:var(--rosa-osc);
  position:relative;
}
.titulo-catalogo:after{
  content:'';
  width:80px;height:4px;
  background:linear-gradient(90deg,var(--rosa),var(--morado));
  display:block;margin:12px auto 0;border-radius:2px;
}
.productos-grid{
  max-width:1350px;
  margin:0 auto;
  padding:0 20px;
  display:grid;
  gap:26px;
  grid-template-columns:1fr;
}
@media(min-width:480px){.productos-grid{grid-template-columns:repeat(2,1fr)}}
@media(min-width:768px){.productos-grid{grid-template-columns:repeat(3,1fr)}}
@media(min-width:1120px){.productos-grid{grid-template-columns:repeat(4,1fr)}}

.card{
  background:#fff;
  border-radius:12px;
  box-shadow:var(--sombra);
  overflow:hidden;
  position:relative;
  transition:transform .25s,box-shadow .25s;
}
.card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(173,20,87,0.18)}
.admin-delete{
  position:absolute;top:10px;right:10px;
  background:#f44336;color:white;border:none;
  width:30px;height:30px;border-radius:50%;
  cursor:pointer;font-size:16px;z-index:5;
  display:none;align-items:center;justify-content:center;
  box-shadow:0 2px 8px rgba(0,0,0,.3);
}
body.admin-active .admin-delete{display:flex}
.gallery{
  position:relative;
  aspect-ratio:1/1;
  background:#f3f3f3;
  overflow:hidden;
}
.gallery img,.gallery video{
  width:100%;height:100%;object-fit:cover;
  display:none;
}
.gallery .active{display:block}
.nav-arrow{
  position:absolute;top:50%;transform:translateY(-50%);
  background:rgba(255,255,255,.85);border:none;
  width:36px;height:36px;border-radius:50%;
  cursor:pointer;font-size:22px;color:#333;
  opacity:0;transition:.2s;z-index:3;
  display:flex;align-items:center;justify-content:center;
}
.gallery:hover .nav-arrow{opacity:1}
.nav-arrow.left{left:10px}
.nav-arrow.right{right:10px}
.dots{
  position:absolute;bottom:10px;left:0;right:0;
  display:flex;justify-content:center;gap:6px;z-index:3;
}
.dot{
  width:8px;height:8px;border-radius:50%;
  background:rgba(255,255,255,.6);cursor:pointer;
  transition:.2s;
}
.dot.active{background:white;width:20px;border-radius:4px}
.card-body{padding:16px}
.card-title{
  font-family:'Playfair Display',serif;
  font-size:1.15rem;margin-bottom:8px;min-height:44px;
}
.card-meta{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:14px;
}
.precio{
  color:var(--rosa-osc);font-weight:700;font-size:1.25rem;
}
.stock{font-size:.85rem;color:#666;background:#f5f5f5;padding:4px 8px;border-radius:6px}
.stock.bajo{color:var(--rosa);background:#fce4ec;font-weight:600}
.btn-agregar{
  width:100%;background:linear-gradient(135deg,var(--rosa),var(--morado));
  color:white;border:none;padding:12px;border-radius:8px;
  font-weight:600;cursor:pointer;transition:.2s;font-size:.95rem;
}
.btn-agregar:hover{opacity:.92;transform:translateY(-1px)}
.btn-agregar.en-carrito{background:#4caf50}
.btn-agregar:disabled{background:#ccc;cursor:not-allowed}
.btn-agregar.pulse{animation:pulse .3s}
@keyframes pulse{0%{transform:scale(1)}50%{transform:scale(.97)}100%{transform:scale(1)}}

/* BOTONES FLOTANTES */
#btn-carrito{
  position:fixed;bottom:22px;left:22px;
  background:white;border:none;
  box-shadow:0 6px 20px rgba(0,0,0,.18);
  border-radius:50px;padding:14px 20px;
  display:flex;align-items:center;gap:10px;
  cursor:pointer;z-index:900;font-weight:700;
  font-size:.95rem;color:var(--rosa-osc);
  transition:.2s;
}
#btn-carrito:hover{transform:translateY(-2px)}
#contador-carrito{
  background:var(--rosa);color:white;border-radius:50%;
  width:24px;height:24px;display:flex;align-items:center;justify-content:center;
  font-size:.8rem;font-weight:700;
}
#btn-admin{
  position:fixed;bottom:22px;right:22px;
  background:linear-gradient(135deg,var(--rosa),var(--morado));
  color:white;border:none;width:58px;height:58px;border-radius:50%;
  box-shadow:0 6px 20px rgba(156,39,176,.4);
  cursor:pointer;z-index:900;font-size:24px;
  transition:.25s;
}
#btn-admin:hover{transform:rotate(90deg) scale(1.05)}

/* PANEL ADMIN */
#panel-admin{
  position:fixed;bottom:90px;right:22px;
  background:white;width:350px;max-width:calc(100vw - 30px);
  border-radius:14px;box-shadow:0 12px 40px rgba(0,0,0,.25);
  padding:22px;display:none;z-index:950;max-height:82vh;overflow-y:auto;
}
#panel-admin.activo{display:block;animation:slideUp .3s}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
#panel-admin h3{
  font-family:'Playfair Display',serif;color:var(--rosa-osc);
  margin-bottom:16px;font-size:1.4rem;
}
#panel-admin label{display:block;font-size:.85rem;font-weight:600;margin:12px 0 5px;color:#555}
#panel-admin input,#panel-admin select,#panel-admin textarea{
  width:100%;padding:10px 12px;border:1.5px solid #e5e5e5;
  border-radius:8px;font-family:inherit;font-size:.95rem;
  transition:.2s;
}
#panel-admin input:focus,#panel-admin textarea:focus,#panel-admin select:focus{
  outline:none;border-color:var(--rosa);box-shadow:0 0 0 3px rgba(233,30,99,.15)
}
.admin-actions{display:flex;gap:10px;margin-top:18px}
.btn-primary{
  flex:1;background:var(--rosa);color:white;border:none;
  padding:11px;border-radius:8px;font-weight:600;cursor:pointer;
}
.btn-danger{
  background:#f5f5f5;color:#d32f2f;border:none;
  padding:11px 14px;border-radius:8px;font-weight:600;cursor:pointer;
}

/* MODAL CARRITO */
#modal-carrito{
  position:fixed;inset:0;background:rgba(0,0,0,.55);
  display:none;align-items:flex-end;justify-content:flex-start;
  z-index:2000;padding:20px;
}
#modal-carrito.activo{display:flex}
.carrito-content{
  background:white;width:420px;max-width:100%;
  border-radius:16px;max-height:88vh;display:flex;flex-direction:column;
  box-shadow:0 20px 60px rgba(0,0,0,.3);animation:slideUp .3s;
  margin-left:0;
}
.carrito-header{
  padding:18px 20px;border-bottom:1px solid #eee;
  display:flex;justify-content:space-between;align-items:center;
}
.carrito-header h3{font-family:'Playfair Display',serif;color:var(--rosa-osc);font-size:1.4rem}
.carrito-header button{background:none;border:none;font-size:22px;cursor:pointer;color:#999}
.carrito-items{flex:1;overflow-y:auto;padding:14px 16px}
.carrito-item{
  display:flex;gap:12px;align-items:center;
  padding:12px 0;border-bottom:1px solid #f0f0f0;
}
.carrito-item img{width:60px;height:60px;object-fit:cover;border-radius:8px;background:#f5f5f5}
.carrito-item .info{flex:1}
.carrito-item .info strong{display:block;font-size:.92rem;margin-bottom:3px}
.carrito-item .info span{color:var(--rosa-osc);font-weight:600;font-size:.9rem}
.carrito-item .controles{display:flex;align-items:center;gap:6px}
.carrito-item .controles button{
  width:26px;height:26px;border:1px solid #ddd;background:white;
  border-radius:6px;cursor:pointer;font-weight:700;
}
.carrito-item .controles span{min-width:22px;text-align:center;font-weight:600}
.eliminar-item{background:none;border:none;color:#f44336;cursor:pointer;font-size:18px;padding:4px}
.carrito-footer{padding:16px;border-top:1px solid #eee;background:#fafafa;border-radius:0 0 16px 16px}
.carrito-footer label{font-size:.85rem;font-weight:600;color:#555;display:block;margin-bottom:6px}
#carrito-notas{
  width:100%;padding:10px;border:1.5px solid #e5e5e5;border-radius:8px;
  font-family:inherit;resize:vertical;min-height:60px;margin-bottom:12px;
}
.total{
  display:flex;justify-content:space-between;align-items:center;
  font-weight:700;font-size:1.1rem;margin-bottom:14px;color:var(--rosa-osc);
}
.carrito-botones{display:flex;gap:10px}
.btn-vaciar{flex:0 0 auto;background:#eee;border:none;padding:12px 16px;border-radius:10px;font-weight:600;cursor:pointer;color:#666}
.btn-whatsapp{
  flex:1;background:#25D366;color:white;border:none;
  padding:12px;border-radius:10px;font-weight:700;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:8px;
  font-size:.95rem;
}
.btn-whatsapp:hover{filter:brightness(.95)}
@media(max-width:480px){
  #modal-carrito{padding:0;align-items:flex-end}
  .carrito-content{width:100%;border-radius:16px 16px 0 0;max-height:85vh}
}
</style>
</head>
<body>

<header>
  <img src="https://drive.google.com/thumbnail?id=1KjnZFq73fVtcJCpujO0Bfbcw-hS3D54J&sz=w1920" alt="Todo para tus uñas - Banner principal" class="banner-principal">
  <img src="https://drive.google.com/thumbnail?id=1uZ4L0fhQlnULPaMtyDYD5YbAIT7EamwU&sz=w1920" alt="Productos profesionales" class="banner-secundario">
</header>

<section class="reels">
  <div class="container">
    <h2>Inspírate con nuestros Reels</h2>
    <div class="reels-grid">
      <blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/reel/DW6to73kqvS/" data-instgrm-version="14"></blockquote>
      <blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/reel/DWEu7cJgFqH/" data-instgrm-version="14"></blockquote>
      <blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/reel/DWEuXSNADuI/" data-instgrm-version="14"></blockquote>
      <blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/reel/DXPXfx1EvuQ/" data-instgrm-version="14"></blockquote>
    </div>
  </div>
</section>

<main id="catalogo">
  <h2 class="titulo-catalogo">Nuestro Catálogo</h2>
  <div id="productos-grid" class="productos-grid"></div>
</main>

<button id="btn-carrito" onclick="toggleCarrito()">
  <span>🛒</span>
  <span>Carrito</span>
  <span id="contador-carrito" style="display:none">0</span>
</button>

<button id="btn-admin" onclick="toggleAdmin()" title="Modo Administrador">⚙️</button>

<div id="panel-admin">
  <h3>Modo Administrador</h3>
  <label>Tipo de media</label>
  <select id="admin-tipo">
    <option value="imagen">Imagen</option>
    <option value="video">Video</option>
  </select>
  <label>URLs de Google Drive (separadas por coma o línea)</label>
  <textarea id="admin-urls" rows="3" placeholder="https://drive.google.com/file/d/ID..."></textarea>
  <label>Nombre del producto</label>
  <input id="admin-nombre" type="text" placeholder="Ej: Esmalte gel rosa">
  <label>Precio (Bs.)</label>
  <input id="admin-precio" type="number" step="0.01" placeholder="0.00">
  <label>Stock disponible</label>
  <input id="admin-stock" type="number" placeholder="0">
  <div class="admin-actions">
    <button class="btn-primary" onclick="agregarProducto()">Agregar Producto</button>
    <button class="btn-danger" onclick="limpiarProductos()">Limpiar Todo</button>
  </div>
</div>

<div id="modal-carrito" onclick="if(event.target.id==='modal-carrito') toggleCarrito()">
  <div class="carrito-content">
    <div class="carrito-header">
      <h3>Tu Carrito</h3>
      <button onclick="toggleCarrito()">✕</button>
    </div>
    <div id="carrito-items" class="carrito-items"></div>
    <div class="carrito-footer">
      <label for="carrito-notas">Notas para tu pedido:</label>
      <textarea id="carrito-notas" placeholder="Color, talla, dirección de entrega..."></textarea>
      <div class="total">Total: <span id="carrito-total">Bs. 0.00</span></div>
      <div class="carrito-botones">
        <button class="btn-vaciar" onclick="vaciarCarrito()">Vaciar</button>
        <button class="btn-whatsapp" onclick="enviarWhatsApp()">
          <span>💬</span> Pedir por WhatsApp
        </button>
      </div>
    </div>
  </div>
</div>

<script async src="https://www.instagram.com/embed.js"></script>
<script>
// === DATOS Y PERSISTENCIA ===
let productos = JSON.parse(localStorage.getItem('tptun_productos')) || [];
let carrito = JSON.parse(localStorage.getItem('tptun_carrito')) || [];
let adminActivo = false;

// Productos demo iniciales
if(productos.length === 0){
  productos = [
    {
      id: 1,
      tipo: 'imagen',
      media: [
        'https://drive.google.com/thumbnail?id=1KjnZFq73fVtcJCpujO0Bfbcw-hS3D54J&sz=w1000',
        'https://drive.google.com/thumbnail?id=1uZ4L0fhQlnULPaMtyDYD5YbAIT7EamwU&sz=w1000'
      ],
      nombre: 'Kit Acrílico Profesional Completo',
      precio: 285,
      stock: 12,
      stockInicial: 12
    },
    {
      id: 2,
      tipo: 'imagen',
      media: [
        'https://drive.google.com/thumbnail?id=1uZ4L0fhQlnULPaMtyDYD5YbAIT7EamwU&sz=w1000'
      ],
      nombre: 'Lámpara UV LED 48W - Rosa',
      precio: 195.50,
      stock: 8,
      stockInicial: 8
    },
    {
      id: 3,
      tipo: 'imagen',
      media: [
        'https://drive.google.com/thumbnail?id=1KjnZFq73fVtcJCpujO0Bfbcw-hS3D54J&sz=w1000'
      ],
      nombre: 'Set Tips Coffin 240 pcs',
      precio: 45,
      stock: 25,
      stockInicial: 25
    },
    {
      id: 4,
      tipo: 'imagen',
      media: [
        'https://drive.google.com/thumbnail?id=1uZ4L0fhQlnULPaMtyDYD5YbAIT7EamwU&sz=w1000',
        'https://drive.google.com/thumbnail?id=1KjnZFq73fVtcJCpujO0Bfbcw-hS3D54J&sz=w1000'
      ],
      nombre: 'Esmaltes Gel Semipermanente x6',
      precio: 120,
      stock: 15,
      stockInicial: 15
    }
  ];
  guardarDatos();
}

function guardarDatos(){
  localStorage.setItem('tptun_productos', JSON.stringify(productos));
  localStorage.setItem('tptun_carrito', JSON.stringify(carrito));
}

// Convertir URL de Drive a thumbnail
function convertirDrive(url){
  try{
    url = url.trim();
    let id = null;
    const m1 = url.match(/\/d\/([a-zA-Z0-9_-]+)/);
    const m2 = url.match(/[?&]id=([a-zA-Z0-9_-]+)/);
    const m3 = url.match(/thumbnail\?id=([a-zA-Z0-9_-]+)/);
    if(m1) id = m1[1];
    else if(m2) id = m2[1];
    else if(m3) id = m3[1];
    else if(url.length > 20 && !url.includes('http')) id = url;
    if(id) return `https://drive.google.com/thumbnail?id=${id}&sz=w1000`;
    return url;
  }catch(e){ return url; }
}

// === ADMIN ===
function toggleAdmin(){
  adminActivo = !adminActivo;
  document.body.classList.toggle('admin-active', adminActivo);
  document.getElementById('panel-admin').classList.toggle('activo', adminActivo);
  document.getElementById('btn-admin').textContent = adminActivo ? '✕' : '⚙️';
}

function agregarProducto(){
  const tipo = document.getElementById('admin-tipo').value;
  const urlsTexto = document.getElementById('admin-urls').value;
  const nombre = document.getElementById('admin-nombre').value.trim();
  const precio = parseFloat(document.getElementById('admin-precio').value);
  const stock = parseInt(document.getElementById('admin-stock').value);

  if(!nombre || isNaN(precio) || isNaN(stock) || !urlsTexto){
    alert('Por favor completa todos los campos');
    return;
  }

  const listaUrls = urlsTexto.split(/[\n,]+/).map(u=>u.trim()).filter(Boolean).map(convertirDrive);
  if(listaUrls.length === 0){
    alert('Ingresa al menos una URL válida');
    return;
  }

  const nuevo = {
    id: Date.now(),
    tipo,
    media: listaUrls,
    nombre,
    precio,
    stock,
    stockInicial: stock
  };
  productos.unshift(nuevo);
  guardarDatos();
  cargarProductos();
  
  // Limpiar form
  document.getElementById('admin-urls').value = '';
  document.getElementById('admin-nombre').value = '';
  document.getElementById('admin-precio').value = '';
  document.getElementById('admin-stock').value = '';
  
  alert('✓ Producto agregado correctamente');
}

function limpiarProductos(){
  if(confirm('¿Estás segura de eliminar TODOS los productos? Esta acción no se puede deshacer.')){
    productos = [];
    carrito = [];
    guardarDatos();
    cargarProductos();
    renderizarCarrito();
  }
}

function eliminarProducto(id){
  if(!adminActivo) return;
  if(!confirm('¿Eliminar este producto?')) return;
  
  // Devolver stock al inventario
  const itemCarrito = carrito.find(i=>i.id===id);
  if(itemCarrito){
    const prod = productos.find(p=>p.id===id);
    if(prod) prod.stock += itemCarrito.cantidad;
    carrito = carrito.filter(i=>i.id!==id);
  }
  
  productos = productos.filter(p=>p.id!==id);
  guardarDatos();
  cargarProductos();
  renderizarCarrito();
}

// === CATÁLOGO ===
function cargarProductos(){
  const grid = document.getElementById('productos-grid');
  grid.innerHTML = '';
  
  if(productos.length === 0){
    grid.innerHTML = '<p style="grid-column:1/-1;text-align:center;color:#999;padding:60px 20px">No hay productos aún. Activa el modo admin (⚙️) para agregar tu primer producto.</p>';
    return;
  }
  
  productos.forEach(prod => {
    const enCarrito = carrito.find(i=>i.id===prod.id);
    const cantidad = enCarrito ? enCarrito.cantidad : 0;
    
    const card = document.createElement('div');
    card.className = 'card';
    card.dataset.id = prod.id;
    
    let mediaHtml = '';
    prod.media.forEach((src, idx)=>{
      if(prod.tipo === 'video'){
        mediaHtml += `<video src="${src}" class="${idx===0?'active':''}" muted loop playsinline></video>`;
      } else {
        mediaHtml += `<img src="${src}" alt="${prod.nombre}" class="${idx===0?'active':''}" loading="lazy">`;
      }
    });
    
    const dotsHtml = prod.media.length > 1 ? 
      prod.media.map((_,i)=>`<span class="dot ${i===0?'active':''}" onclick="irAImagen(${prod.id},${i})"></span>`).join('') : '';
    
    const flechas = prod.media.length > 1 ? `
      <button class="nav-arrow left" onclick="cambiarImagen(${prod.id},-1)">‹</button>
      <button class="nav-arrow right" onclick="cambiarImagen(${prod.id},1)">›</button>
      <div class="dots">${dotsHtml}</div>
    ` : '';
    
    card.innerHTML = `
      <button class="admin-delete" onclick="eliminarProducto(${prod.id})" title="Eliminar producto">✕</button>
      <div class="gallery">
        ${mediaHtml}
        ${flechas}
      </div>
      <div class="card-body">
        <h3 class="card-title">${prod.nombre}</h3>
        <div class="card-meta">
          <span class="precio">Bs. ${prod.precio.toFixed(2)}</span>
          <span class="stock ${prod.stock<5?'bajo':''}">Stock: ${prod.stock}</span>
        </div>
        <button class="btn-agregar ${cantidad>0?'en-carrito':''}" 
                onclick="agregarAlCarrito(${prod.id})" 
                ${prod.stock===0?'disabled':''}>
          ${cantidad>0 ? `En carrito (${cantidad})` : prod.stock===0 ? 'Sin stock' : 'Agregar al carrito'}
        </button>
      </div>
    `;
    grid.appendChild(card);
  });
}

function cambiarImagen(id, direccion){
  const card = document.querySelector(`.card[data-id="${id}"]`);
  if(!card) return;
  const items = card.querySelectorAll('.gallery img, .gallery video');
  const dots = card.querySelectorAll('.dot');
  if(items.length <= 1) return;
  
  let idx = Array.from(items).findIndex(el=>el.classList.contains('active'));
  items[idx].classList.remove('active');
  if(dots[idx]) dots[idx].classList.remove('active');
  
  idx = (idx + direccion + items.length) % items.length;
  items[idx].classList.add('active');
  if(dots[idx]) dots[idx].classList.add('active');
}

function irAImagen(id, indice){
  const card = document.querySelector(`.card[data-id="${id}"]`);
  const items = card.querySelectorAll('.gallery img, .gallery video');
  const dots = card.querySelectorAll('.dot');
  
  items.forEach(el=>el.classList.remove('active'));
  dots.forEach(d=>d.classList.remove('active'));
  
  if(items[indice]) items[indice].classList.add('active');
  if(dots[indice]) dots[indice].classList.add('active');
}

// === CARRITO ===
function agregarAlCarrito(id){
  const prod = productos.find(p=>p.id===id);
  if(!prod || prod.stock <= 0){
    alert('Producto sin stock disponible');
    return;
  }
  
  const item = carrito.find(i=>i.id===id);
  if(item){
    item.cantidad++;
  } else {
    carrito.push({
      id: prod.id,
      nombre: prod.nombre,
      precio: prod.precio,
      cantidad: 1,
      imagen: prod.media[0]
    });
  }
  
  prod.stock--;
  guardarDatos();
  cargarProductos();
  renderizarCarrito();
  
  // Feedback visual
  const btn = document.querySelector(`.card[data-id="${id}"] .btn-agregar`);
  if(btn){
    btn.classList.add('pulse');
    setTimeout(()=>btn.classList.remove('pulse'), 300);
  }
}

function toggleCarrito(){
  document.getElementById('modal-carrito').classList.toggle('activo');
}

function renderizarCarrito(){
  const contenedor = document.getElementById('carrito-items');
  const contador = document.getElementById('contador-carrito');
  const totalEl = document.getElementById('carrito-total');
  
  contenedor.innerHTML = '';
  let total = 0;
  let cantidadTotal = 0;
  
  carrito.forEach(item=>{
    total += item.precio * item.cantidad;
    cantidadTotal += item.cantidad;
    
    const div = document.createElement('div');
    div.className = 'carrito-item';
    div.innerHTML = `
      <img src="${item.imagen}" alt="${item.nombre}">
      <div class="info">
        <strong>${item.nombre}</strong>
        <span>Bs. ${item.precio.toFixed(2)}</span>
      </div>
      <div class="controles">
        <button onclick="cambiarCantidad(${item.id},-1)">−</button>
        <span>${item.cantidad}</span>
        <button onclick="cambiarCantidad(${item.id},1)">+</button>
      </div>
      <button class="eliminar-item" onclick="quitarDelCarrito(${item.id})" title="Quitar">✕</button>
    `;
    contenedor.appendChild(div);
  });
  
  contador.textContent = cantidadTotal;
  contador.style.display = cantidadTotal > 0 ? 'flex' : 'none';
  totalEl.textContent = `Bs. ${total.toFixed(2)}`;
  
  if(carrito.length === 0){
    contenedor.innerHTML = '<p style="text-align:center;color:#999;padding:40px 20px">Tu carrito está vacío<br><small>Agrega productos del catálogo</small></p>';
  }
}

function cambiarCantidad(id, delta){
  const item = carrito.find(i=>i.id===id);
  const prod = productos.find(p=>p.id===id);
  if(!item || !prod) return;
  
  if(delta > 0){
    if(prod.stock <= 0){
      alert('No hay más stock disponible');
      return;
    }
    item.cantidad++;
    prod.stock--;
  } else {
    item.cantidad--;
    prod.stock++;
    if(item.cantidad <= 0){
      carrito = carrito.filter(i=>i.id!==id);
    }
  }
  
  guardarDatos();
  cargarProductos();
  renderizarCarrito();
}

function quitarDelCarrito(id){
  const item = carrito.find(i=>i.id===id);
  const prod = productos.find(p=>p.id===id);
  if(item && prod){
    prod.stock += item.cantidad;
  }
  carrito = carrito.filter(i=>i.id!==id);
  guardarDatos();
  cargarProductos();
  renderizarCarrito();
}

function vaciarCarrito(){
  if(carrito.length === 0) return;
  if(!confirm('¿Vaciar todo el carrito?')) return;
  
  carrito.forEach(item=>{
    const prod = productos.find(p=>p.id===item.id);
    if(prod) prod.stock += item.cantidad;
  });
  
  carrito = [];
  guardarDatos();
  cargarProductos();
  renderizarCarrito();
}

function enviarWhatsApp(){
  if(carrito.length === 0){
    alert('Tu carrito está vacío');
    return;
  }
  
  const notas = document.getElementById('carrito-notas').value.trim();
  let mensaje = '¡Hola! 👋 Quiero hacer un pedido de *Todo para tus uñas*:%0A%0A';
  let total = 0;
  
  carrito.forEach(item=>{
    const subtotal = item.precio * item.cantidad;
    total += subtotal;
    mensaje += `• ${item.nombre} x${item.cantidad} - Bs. ${subtotal.toFixed(2)}%0A`;
  });
  
  mensaje += `%0A*TOTAL: Bs. ${total.toFixed(2)}*`;
  
  if(notas){
    mensaje += `%0A%0A📝 *Notas:* ${encodeURIComponent(notas)}`;
  }
  
  mensaje += `%0A%0AGracias! 💅`;
  
  window.open(`https://wa.me/59163882223?text=${mensaje}`, '_blank');
}

// === INICIO ===
window.addEventListener('DOMContentLoaded', ()=>{
  cargarProductos();
  renderizarCarrito();
  // Reprocesar embeds de Instagram por si acaso
  setTimeout(()=>{
    if(window.instgrm && window.instgrm.Embeds){
      window.instgrm.Embeds.process();
    }
  }, 1000);
});
